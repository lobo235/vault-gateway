# Vault server URL.
VAULT_ADDR=https://vault.example.com:8200

# AppRole credentials (injected via Nomad Workload Identity in production).
VAULT_ROLE_ID=your-vault-role-id-here
VAULT_SECRET_ID=your-vault-secret-id-here

# Bearer token callers must present to use this API.
GATEWAY_API_KEY=your-gateway-api-key-here

# Port this gateway listens on. Default: 8080
PORT=8080

# Log level: debug, info, warn, error. Default: info
LOG_LEVEL=info
